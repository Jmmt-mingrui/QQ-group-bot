# QQ Bot 配置
BOT_QQ=                    # Bot 登录的 QQ 号
BOT_WS_PORT=8080           # WebSocket 监听端口 (NapCatQQ 连入)
GROUP_IDS=                 # 监控的群号，逗号分隔，如: "123456,789012"

# NapCatQQ OneBot v11 连接配置
ONEBOT_WS_PATH=/ws         # WebSocket 路径
ONEBOT_ACCESS_TOKEN=       # OneBot access_token (需与 NapCatQQ 配置一致)

# LLM
LLM_API_URL=               # OpenAI 兼容 API 地址
LLM_API_KEY=               # API Key
LLM_MODEL=                 # 模型名称

# 总结
SUMMARY_HOUR=23             # 每日总结时间（小时）
SUMMARY_PROMPT_FILE=./skills/summary.md  # 总结 System Prompt

# 数据库
DB_PATH=./data/bot.db       # SQLite 数据库路径
